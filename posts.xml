---
layout: null
---
<?xml version="1.0"?>
<feed xmlns="http://www.w3.org/2005/Atom">
 
  <title>lvsl.github.io</title>
  <link href="https://lvsl.github.io/"/>
  <link type="application/atom+xml" rel="self" href="https://lvsl.github.io/posts.xml"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>https://lvsl.github.io/</id>
  <author>
    <name>Leonid Vasilyev</name>
    <email>vsleonid+blog@gmail.com</email>
  </author>

  {% for post in site.posts %}
  <entry>
    <id>https://lvsl.github.io/{{ post.id }}</id>
    <link type="text/html" rel="alternate" href="https://lvsl.github.io{{ post.url }}"/>
    <title>{{ post.title }}</title>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <author>
      <name>Leonid Vasilyev</name>
      <email>vsleonid+blog@gmail.com</email>
    </author>
    <content type="html">{{ post.content | xml_escape }}</content>
  </entry>
  {% endfor %}
 
</feed>
